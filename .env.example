# 200x Commander — API 密钥配置（复制为 .env 填入真实值）
# Gate.io: 个人中心 → API 管理 → 创建（开启 合约交易 权限）
GATE_API_KEY=your_api_key_here
GATE_API_SECRET=your_api_secret_here

# 企微 Webhook（排行榜 + Commander 交易通知共用）
# 从企微群 → 群机器人 → 添加 → 复制 Webhook URL
WECHAT_WORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# PushPlus 推送（可选，微信个人通知）
# PUSHPLUS_TOKEN=your_token_here
